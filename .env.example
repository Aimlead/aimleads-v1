# ─── Required for production ──────────────────────────────────────────────────
NODE_ENV=production
API_PORT=3010

# Optional but recommended for deploy truth / build fingerprinting
# These values are injected into the frontend build stamp and /api/health
# APP_VERSION=2026.04.15-1
# APP_BUILD_TIME=2026-04-15T20:30:00Z
# APP_COMMIT_SHA=abc1234

# Session secret — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=CHANGE_ME_generate_a_random_48_byte_hex_string

# CORS — production domain
CORS_ORIGIN=https://aimlead.io

# Trust proxy: 1 = one proxy hop (Traefik -> Express); set to 2 if nginx sits between Traefik and Express
TRUST_PROXY=1

# Data & auth
DATA_PROVIDER=supabase
AUTH_PROVIDER=supabase
ENABLE_DEMO_BOOTSTRAP=false
ENABLE_API_DOCS=false
SUPABASE_FALLBACK_TO_LOCAL=false

# ─── Supabase (required) ──────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── AI / Enrichment API keys (all optional, graceful degradation if missing) ─
# Anthropic (required for lead analysis + outreach generation)
ANTHROPIC_API_KEY=sk-ant-...

# LLM model override (defaults to claude-sonnet-4-6)
# LLM_MODEL=claude-sonnet-4-6

# Hunter.io — email discovery (https://hunter.io/api)
HUNTER_API_KEY=

# NewsAPI — company news signals (https://newsapi.org) — requires Business plan for production
# Alternative: leave empty and rely on Claude web_search (included in Anthropic billing)
NEWS_API_KEY=

# ─── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# ─── CRM Integration (configured per workspace in the CRM Integration UI) ────
# Tokens are stored per workspace in the crm_integrations table (not in .env).
# HubSpot  : create a Private App at https://app.hubspot.com/private-apps
#            Scopes needed: crm.objects.contacts.write, crm.objects.contacts.read
# Salesforce: use a connected app OAuth access token + instance URL
#             Custom fields required on Lead object: AimLeads_Score__c, AimLeads_Category__c

# ─── Rate limiting (optional overrides) ──────────────────────────────────────
# API_RATE_LIMIT_WINDOW_MS=900000
# API_RATE_LIMIT_MAX=600
# AUTH_RATE_LIMIT_WINDOW_MS=600000
# AUTH_RATE_LIMIT_MAX=30
# RATE_LIMIT_BACKEND=memory
#
# Optional distributed rate limiting / login lockout via Upstash Redis REST.
# If both variables below are set, AimLeads can automatically switch to the
# Upstash backend even when RATE_LIMIT_BACKEND is omitted.
# RATE_LIMIT_BACKEND=upstash
# UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token
