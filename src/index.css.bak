@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  :root {
    /* ── AImlead design system ── */
    --background: 221 100% 15%;      /* #001F4D navy */
    --foreground: 210 40% 94%;
    --card: 221 80% 11%;             /* slightly darker than navy for cards */
    --card-foreground: 210 40% 94%;
    --popover: 221 80% 11%;
    --popover-foreground: 210 40% 94%;
    --primary: 213 100% 61%;         /* #3A8DFF sky */
    --primary-foreground: 0 0% 100%;
    --secondary: 221 50% 18%;
    --secondary-foreground: 210 30% 80%;
    --muted: 221 50% 16%;
    --muted-foreground: 215 20% 52%;
    --accent: 142 62% 60%;           /* #5AD38C mint */
    --accent-foreground: 0 0% 100%;
    --destructive: 4 86% 58%;        /* #FF6F61 coral */
    --destructive-foreground: 0 0% 100%;
    --border: 221 40% 20%;
    --input: 221 40% 16%;
    --ring: 213 100% 61%;
    --radius: 0.625rem;
    --sidebar-background: 221 100% 15%;
    --sidebar-foreground: 210 40% 94%;
    --sidebar-primary: 213 100% 61%;
    --sidebar-primary-foreground: 0 0% 100%;
    --sidebar-accent: 221 50% 20%;
    --sidebar-accent-foreground: 210 40% 94%;
    --sidebar-border: 221 40% 20%;
    --sidebar-ring: 213 100% 61%;

    /* ── Raw palette (for non-Tailwind use) ── */
    --c-navy:    #001F4D;
    --c-sky:     #3A8DFF;
    --c-sky2:    #2a7df0;
    --c-mint:    #5AD38C;
    --c-coral:   #FF6F61;
    --c-sand:    #F5F0E8;
  }
}

@layer base {
  * { @apply border-border outline-ring/50; }
  body { @apply bg-background text-foreground; font-family: 'Outfit', system-ui, sans-serif; }
  h1, h2, h3, h4, h5, h6 { font-family: 'Bricolage Grotesque', system-ui, sans-serif; }
}

/* ── AImlead app global animations ── */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

/* ── AImlead pill button (for app use outside landing) ── */
.aimlead-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 22px;
  border-radius: 100px;
  font-family: 'Outfit', sans-serif;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  transition: box-shadow .25s, color .25s;
  border: none;
  text-decoration: none;
}

.aimlead-btn-sky {
  background: rgba(58,141,255,.12);
  color: #3A8DFF;
  border: 1px solid rgba(58,141,255,.2);
}

.aimlead-btn-sky::before {
  content: '';
  position: absolute;
  left: 4px;
  top: 50%;
  transform: translateY(-50%);
  width: 34px;
  height: 34px;
  border-radius: 100px;
  background: #3A8DFF;
  transition: width .45s cubic-bezier(.4,0,.2,1);
  z-index: 0;
}

.aimlead-btn-sky:hover::before { width: calc(100% - 8px); }
.aimlead-btn-sky:hover { color: #fff; box-shadow: 0 8px 28px rgba(58,141,255,.4); }
.aimlead-btn-sky > * { position: relative; z-index: 1; }

.aimlead-btn-mint {
  background: rgba(90,211,140,.1);
  color: #5AD38C;
  border: 1px solid rgba(90,211,140,.2);
}

.aimlead-btn-mint::before {
  content: '';
  position: absolute;
  left: 4px;
  top: 50%;
  transform: translateY(-50%);
  width: 34px;
  height: 34px;
  border-radius: 100px;
  background: #5AD38C;
  transition: width .45s cubic-bezier(.4,0,.2,1);
  z-index: 0;
}

.aimlead-btn-mint:hover::before { width: calc(100% - 8px); }
.aimlead-btn-mint:hover { color: #001F4D; box-shadow: 0 8px 28px rgba(90,211,140,.35); }
.aimlead-btn-mint > * { position: relative; z-index: 1; }

/* ── Mobile / iOS safe areas ── */
@layer utilities {
  .pb-safe-area-bottom {
    padding-bottom: max(2rem, env(safe-area-inset-bottom));
  }
  .pt-safe-area-top {
    padding-top: env(safe-area-inset-top);
  }
}

/* ── Login page ── */
.login-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1.5rem;
  background: linear-gradient(135deg, #000d24 0%, #001F4D 40%, #00275E 70%, #001a3d 100%);
  position: relative;
  overflow: hidden;
}

.login-bg-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(100px);
  opacity: .25;
  pointer-events: none;
}
.login-bg-glow--1 {
  width: 500px; height: 500px;
  background: #3A8DFF;
  top: -120px; right: -80px;
}
.login-bg-glow--2 {
  width: 400px; height: 400px;
  background: #5AD38C;
  bottom: -100px; left: -60px;
}

.login-card {
  width: 100%;
  max-width: 420px;
  background: rgba(255,255,255,.97);
  backdrop-filter: blur(20px);
  border-radius: 20px;
  padding: 2.5rem 2rem;
  box-shadow:
    0 4px 6px rgba(0,0,0,.04),
    0 20px 50px rgba(0,31,77,.18),
    inset 0 1px 0 rgba(255,255,255,.6);
  position: relative;
  z-index: 1;
}

.login-title {
  font-family: 'Bricolage Grotesque', system-ui, sans-serif;
  font-size: 1.5rem;
  font-weight: 700;
  color: #0f172a;
  text-align: center;
  margin-bottom: 0.25rem;
}

.login-subtitle {
  font-size: 0.875rem;
  color: #64748b;
  text-align: center;
  margin-bottom: 1.75rem;
}

.login-form {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.login-field {
  display: flex;
  flex-direction: column;
  gap: 0.375rem;
}

.login-label {
  font-size: 0.8125rem;
  font-weight: 500;
  color: #334155;
}

.login-input-wrap {
  position: relative;
}

.login-input-icon {
  position: absolute;
  left: 0.75rem;
  top: 50%;
  transform: translateY(-50%);
  width: 1rem;
  height: 1rem;
  color: #94a3b8;
  pointer-events: none;
}

.login-input {
  width: 100%;
  height: 2.75rem;
  padding: 0 0.75rem 0 2.5rem;
  font-size: 0.875rem;
  color: #0f172a;
  background: #fff;
  border: 1.5px solid #e2e8f0;
  border-radius: 12px;
  outline: none;
  transition: border-color .2s, box-shadow .2s;
  font-family: 'Outfit', system-ui, sans-serif;
}

.login-input::placeholder { color: #94a3b8; }
.login-input:focus {
  border-color: #3A8DFF;
  box-shadow: 0 0 0 3px rgba(58,141,255,.15);
}

.login-input--password { padding-right: 2.75rem; }

.login-eye-btn {
  position: absolute;
  right: 0.75rem;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  color: #94a3b8;
  cursor: pointer;
  padding: 0.25rem;
  transition: color .15s;
}
.login-eye-btn:hover { color: #475569; }

.login-forgot {
  font-size: 0.75rem;
  color: #94a3b8;
  text-decoration: none;
  transition: color .15s;
}
.login-forgot:hover { color: #3A8DFF; }

.login-error {
  font-size: 0.8125rem;
  color: #e11d48;
  background: #fff1f2;
  border: 1px solid #fecdd3;
  border-radius: 12px;
  padding: 0.625rem 0.875rem;
}

.login-submit {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  width: 100%;
  height: 2.75rem;
  margin-top: 0.25rem;
  font-size: 0.875rem;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #3A8DFF 0%, #2a7df0 100%);
  border: none;
  border-radius: 12px;
  cursor: pointer;
  transition: box-shadow .25s, transform .15s;
  font-family: 'Outfit', system-ui, sans-serif;
}
.login-submit:hover {
  box-shadow: 0 8px 28px rgba(58,141,255,.35);
  transform: translateY(-1px);
}
.login-submit:active { transform: translateY(0); }
.login-submit:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none;
}

.login-switch {
  margin-top: 1.25rem;
  text-align: center;
  font-size: 0.8125rem;
  color: #64748b;
}

.login-switch-btn {
  background: none;
  border: none;
  color: #3A8DFF;
  font-weight: 600;
  cursor: pointer;
  font-size: inherit;
  font-family: inherit;
}
.login-switch-btn:hover { text-decoration: underline; }

.login-back {
  margin-top: 0.75rem;
  text-align: center;
}

.login-back-link {
  font-size: 0.75rem;
  color: #94a3b8;
  text-decoration: none;
}
.login-back-link:hover { text-decoration: underline; }

.login-debug {
  margin-top: 0.5rem;
  text-align: center;
  font-size: 0.6875rem;
  color: #94a3b8;
}

/* ── App card enhancement ── */
.app-card {
  background: hsl(var(--card));
  border: 1px solid hsl(var(--border));
  border-radius: 14px;
  transition: border-color .2s, box-shadow .2s;
}

.app-card:hover {
  border-color: rgba(58,141,255,.25);
  box-shadow: 0 4px 24px rgba(0,0,0,.2);
}
